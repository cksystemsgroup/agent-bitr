(set-logic QF_BV)
(set-info :status sat)

; define-fun usage: helper functions for byte manipulation.
; Common pattern in benchmarks generated by software verification tools.

; Byte extraction helpers
(define-fun byte0 ((w (_ BitVec 32))) (_ BitVec 8)
  ((_ extract 7 0) w))

(define-fun byte1 ((w (_ BitVec 32))) (_ BitVec 8)
  ((_ extract 15 8) w))

(define-fun byte2 ((w (_ BitVec 32))) (_ BitVec 8)
  ((_ extract 23 16) w))

(define-fun byte3 ((w (_ BitVec 32))) (_ BitVec 8)
  ((_ extract 31 24) w))

; Reconstruct a word from bytes (little-endian order)
(define-fun mk_word ((b3 (_ BitVec 8)) (b2 (_ BitVec 8))
                     (b1 (_ BitVec 8)) (b0 (_ BitVec 8))) (_ BitVec 32)
  (concat b3 (concat b2 (concat b1 b0))))

; Rotate bytes: [b3 b2 b1 b0] -> [b0 b3 b2 b1]
(define-fun rotate_bytes ((w (_ BitVec 32))) (_ BitVec 32)
  (mk_word (byte0 w) (byte3 w) (byte2 w) (byte1 w)))

(declare-const x (_ BitVec 32))
(declare-const y (_ BitVec 32))

; y is x with bytes rotated
(assert (= y (rotate_bytes x)))

; Constrain x
(assert (= x #x01020304))

; After rotation: [04 01 02 03]
(assert (= y #x04010203))

; Also verify individual byte extraction
(assert (= (byte0 x) #x04))
(assert (= (byte3 x) #x01))

(check-sat)
(exit)
